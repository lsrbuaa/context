{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Context Memory Eval Case",
  "type": "object",
  "required": [
    "case_id",
    "scenario",
    "user_request",
    "current_state",
    "available_memory_ids",
    "expected_memory_ids",
    "forbidden_memory_ids",
    "expected_behavior",
    "risk_checks",
    "scoring"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "user_request": {
      "type": "string"
    },
    "current_state": {
      "type": "object"
    },
    "available_memory_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_memory_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_memory_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_behavior": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoring": {
      "type": "object",
      "required": [
        "retrieval_correctness",
        "policy_compliance",
        "context_efficiency",
        "action_safety"
      ],
      "properties": {
        "retrieval_correctness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "policy_compliance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "conflict_handling": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "context_efficiency": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "action_safety": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
